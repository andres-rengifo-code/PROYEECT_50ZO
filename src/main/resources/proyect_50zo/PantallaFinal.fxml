<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<StackPane style="-fx-background-color: #0a3d0a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyect_50zo.CONTROLLER.PantallaFinalController">
    <VBox alignment="CENTER" spacing="20" style="-fx-padding: 50;">
        <Label style="-fx-font-family: 'Impact'; -fx-font-size: 34px; -fx-text-fill: #f5c518;" text="FIN DEL JUEGO" />
        <Label fx:id="mensajeGanador" style="-fx-font-family: 'Courier New'; -fx-font-size: 20px; -fx-text-fill: white;" text="GANADOR" />
        <Button onAction="#volverAlInicio" style="-fx-background-color: #c9a227; -fx-font-family: 'Impact'; -fx-font-size: 15px; -fx-padding: 10 25 10 25; -fx-cursor: hand;" text="JUGAR DE NUEVO" />
    </VBox>
</StackPane>