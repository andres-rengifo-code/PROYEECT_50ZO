                       style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #4caf81;"/>
            </VBox>


            <VBox fx:id="zonaMaquina2" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0f1f0f; -fx-border-color: #c9a227; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 14 10 14;">
