                    <Label text="MAQUINA 2" style="-fx-font-family: 'Impact'; -fx-font-size: 13px; -fx-text-fill: #c9a227;"/>
                    <Label fx:id="turnoMaq2" text="TURNO" style="-fx-font-family: 'Courier New'; -fx-font-size: 9px; -fx-text-fill: #0a1a00; -fx-background-color: #f5c518; -fx-background-radius: 3; -fx-padding: 1 5 1 5; -fx-opacity: 0;"/>
                </HBox>
