                </HBox>
                <HBox spacing="5" alignment="CENTER">
                    <VBox prefWidth="38" prefHeight="54" alignment="CENTER"
                          style="-fx-background-color: #7a0000; -fx-border-color: #c9a227; -fx-border-width: 1; -fx-background-radius: 5; -fx-border-radius: 5;">
                        <Label text="🂠" style="-fx-font-size: 22px;"/>
                    </VBox>
