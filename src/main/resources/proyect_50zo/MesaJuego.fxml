    <center>
        <VBox alignment="CENTER" spacing="14">

            <Label fx:id="labelTurno" text="▶  TURNO: MAQUINA 1"
                   maxWidth="Infinity"
                   style="-fx-font-family: 'Impact'; -fx-font-size: 15px; -fx-text-fill: #f5c518; -fx-background-color: #1a3a1a; -fx-border-color: #f5c518; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 0 7 0;"
                   alignment="CENTER"/>

            <VBox alignment="CENTER" spacing="4">
                <Label text="M A Z O"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #666; -fx-letter-spacing: 3;"/>
                <VBox fx:id="mazo" prefWidth="62" prefHeight="88" alignment="CENTER"
                      style="-fx-background-color: #7a0000; -fx-border-color: #f5c518; -fx-border-width: 2; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;"
                      onMouseClicked="#pedirCarta">
                    <Label text="🂠" style="-fx-font-size: 36px;"/>
                </VBox>
                <Label fx:id="labelCartasRestantes" text="48 cartas"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #444;"/>
            </VBox>

        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 10 20 18 20;">

            <VBox fx:id="zonaJugador" alignment="CENTER" spacing="8"
                  style="-fx-background-color: #0f1f0f; -fx-border-color: #f5c518; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 20 12 20;">

                <Label text="TU MANO"
                       style="-fx-font-family: 'Impact'; -fx-font-size: 14px; -fx-text-fill: #f5c518; -fx-letter-spacing: 2;"/>

                <HBox fx:id="cartasJugador" spacing="10" alignment="CENTER">
                    <!-- Carta 1 -->
                    <VBox fx:id="jc1" prefWidth="55" prefHeight="80" alignment="CENTER"
                          style="-fx-background-color: #ffffff; -fx-border-color: #333; -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;">
                        <Label fx:id="jc1Val" text="A" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111;"/>
                        <Label fx:id="jc1Palo" text="♠" style="-fx-font-size: 16px; -fx-text-fill: #111;"/>
                    </VBox>
                    <!-- Carta 2 -->
                    <VBox fx:id="jc2" prefWidth="55" prefHeight="80" alignment="CENTER"
                          style="-fx-background-color: #ffffff; -fx-border-color: #333; -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;">
                        <Label fx:id="jc2Val" text="7" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #cc0000;"/>
                        <Label fx:id="jc2Palo" text="♥" style="-fx-font-size: 16px; -fx-text-fill: #cc0000;"/>
                    </VBox>
                    <!-- Carta 3 -->
                    <VBox fx:id="jc3" prefWidth="55" prefHeight="80" alignment="CENTER"
                          style="-fx-background-color: #ffffff; -fx-border-color: #333; -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;">
                        <Label fx:id="jc3Val" text="K" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #cc0000;"/>
                        <Label fx:id="jc3Palo" text="♦" style="-fx-font-size: 16px; -fx-text-fill: #cc0000;"/>
                    </VBox>
                    <!-- Carta 4 -->
                    <VBox fx:id="jc4" prefWidth="55" prefHeight="80" alignment="CENTER"
                          style="-fx-background-color: #ffffff; -fx-border-color: #333; -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;">
                        <Label fx:id="jc4Val" text="3" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111;"/>
                        <Label fx:id="jc4Palo" text="♣" style="-fx-font-size: 16px; -fx-text-fill: #111;"/>
                    </VBox>
                </HBox>

                <Label fx:id="puntajeJugador" text="Tus puntos: 0"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-text-fill: #f5c518; -fx-font-weight: bold;"/>

            </VBox>

            <!-- BOTONES -->
            <HBox spacing="16" alignment="CENTER">
                <Button fx:id="btnPedir" text="+ PEDIR CARTA"
                        style="-fx-background-color: #c9a227; -fx-text-fill: #0a1a00; -fx-font-family: 'Impact'; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 28 10 28;"
                        onAction="#pedirCarta"/>
                <Button fx:id="btnPlantar" text="✋ PLANTARSE"
                        style="-fx-background-color: #7a0000; -fx-text-fill: #f5c518; -fx-font-family: 'Impact'; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 28 10 28;"
                        onAction="#plantarse"/>
            </HBox>

        </VBox>
